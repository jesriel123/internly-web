# Password reset redirect used by Supabase reset email from web login
# Production-first default
REACT_APP_PASSWORD_RESET_REDIRECT=https://internly-web.vercel.app/reset-password
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# LAN development override example (replace with your current LAN IP)
# REACT_APP_PASSWORD_RESET_REDIRECT=http://192.168.68.114:3000/reset-password
